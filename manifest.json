{
  "manifest_version": 3,
  "name": "Super LTC for Point Click Care",
  "version": "1.0.0",
  "description": "Super LTC overlay for Point Click Care",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.pointclickcare.com/*",
    "https://superltc.com/*",
    "http://localhost:5432/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.pointclickcare.com/*"],
      "js": [
        "config.js",
        "lib/pdf.min.js",
        "content/mockData.js",
        "content/evidence-viewers.js",
        "content/section-transformers.js",
        "content/components/modal.js",
        "content/components/dropdown.js",
        "content/components/toast.js",
        "content/queries/query-api.js",
        "content/queries/query-state.js",
        "content/queries/query-badges.js",
        "content/queries/query-panel.js",
        "content/queries/query-modal.js",
        "content/queries/query-send-modal.js",
        "content/icd10-viewer/icd10-mock-data.js",
        "content/icd10-viewer/icd10-api.js",
        "content/icd10-viewer/icd10-sidebar.js",
        "content/icd10-viewer/icd10-evidence-panel.js",
        "content/icd10-viewer/icd10-pdf-viewer.js",
        "content/icd10-viewer/icd10-viewer.js",
        "content/super-menu/state.js",
        "content/super-menu/utils.js",
        "content/super-menu/context.js",
        "content/super-menu/session.js",
        "content/super-menu/fab.js",
        "content/super-menu/panel.js",
        "content/super-menu/navigation.js",
        "content/super-menu/dashboard-state.js",
        "content/super-menu/dashboard-view.js",
        "content/super-menu/facility-dashboard-state.js",
        "content/super-menu/facility-dashboard-view.js",
        "content/super-menu/mds-view.js",
        "content/super-menu/chat-view.js",
        "content/super-menu/streaming.js",
        "content/super-menu/init.js",
        "content/content.js"
      ],
      "css": [
        "content/css/variables.css",
        "content/css/base.css",
        "content/css/popover.css",
        "content/css/panel.css",
        "content/css/sections.css",
        "content/css/evidence-viewer.css",
        "content/css/admin-modal.css",
        "content/css/clinical-notes-modal.css",
        "content/css/therapy-modal.css",
        "content/css/pdf-modal.css",
        "content/css/diagnosis-query-modal.css",
        "content/css/super-components.css",
        "content/css/query.css",
        "content/css/icd10-viewer.css",
        "content/chatbot.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["callback.html", "lib/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
